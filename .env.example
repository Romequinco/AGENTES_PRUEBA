# ── Pipeline principal ───────────────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-...

# Modelos por agente (cambiar para probar calidades/costes distintos)
# Opciones: claude-opus-4-7 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
MODEL_LEADER=claude-opus-4-7
MODEL_ANALYST=claude-sonnet-4-6
MODEL_WRITER=claude-sonnet-4-6

MAX_RETRIES=3
RETRY_DELAY_SECONDS=5
LOG_LEVEL=INFO

DATA_RAW_DIR=data/raw
DATA_ANALYSIS_DIR=data/analysis
OUTPUT_DIR=output
LOGS_DIR=logs

RSS_EXPANSION=https://www.expansion.com/rss/mercados.xml
RSS_CINCO_DIAS=https://cincodias.elpais.com/seccion/rss/mercados/

FINNHUB_API_KEY=

# Descomentar para forzar ejecución fuera de horario de mercado
# FORCE_RUN=true

# ── Base de datos (Fases 1-3) ────────────────────────────────────────────────
# OBLIGATORIO para newsletter, auth, alertas, backtests y portfolios
# Local:   postgresql://user:password@localhost:5432/ibex_newsletter
# Railway: se inyecta automáticamente desde el plugin PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/ibex_newsletter

# ── Newsletter y email (Fase 1) ──────────────────────────────────────────────
# Clave API de SendGrid (obligatorio para envío de emails)
SENDGRID_API_KEY=SG.xxxx...
# Email remitente — debe estar verificado en SendGrid → Sender Authentication
SENDGRID_FROM_EMAIL=newsletter@tudominio.com

# ── Auth JWT (Fase 2) ────────────────────────────────────────────────────────
# Clave secreta para firmar tokens JWT — mínimo 32 caracteres
# Generar: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=cambia-esto-por-una-clave-aleatoria-larga

# ── Stripe — pagos Premium y PRO (Fase 2-3) ──────────────────────────────────
# Claves del dashboard de Stripe → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
# Signing secret del webhook → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs → Products → (Plan Premium / Plan PRO) → Price ID
STRIPE_PREMIUM_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
# URLs de redirección tras pago (opcional — por defecto apuntan a /dashboard.html)
# STRIPE_SUCCESS_URL=https://tu-dominio.railway.app/dashboard.html
# STRIPE_CANCEL_URL=https://tu-dominio.railway.app/dashboard.html

# ── Motor de alertas — APScheduler (Fase 2) ──────────────────────────────────
# Valores por defecto: evaluación diaria a las 17:35 Madrid
# ALERTS_TIMEZONE=Europe/Madrid
# ALERTS_HOUR=17
# ALERTS_MINUTE=35

# ── Monitoring y admin (Fase 4) ──────────────────────────────────────────────
# Email del administrador — recibe alertas de errores críticos via SendGrid
ADMIN_EMAIL=admin@tudominio.com
# Clave para acceder a GET /admin/metrics (header X-Admin-Key)
# Generar: python -c "import secrets; print(secrets.token_hex(24))"
ADMIN_API_KEY=cambia-esto-por-una-clave-segura

# ── API Flask ────────────────────────────────────────────────────────────────
# Railway asigna PORT automáticamente — no configurar en producción
# PORT=5000
# FLASK_DEBUG=false
