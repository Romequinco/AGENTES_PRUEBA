ANTHROPIC_API_KEY=sk-ant-...
FINNHUB_API_KEY=asdsadsd....

# Modelos por agente — cambiar aquí para probar distintas calidades/costes
# Opciones: claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
MODEL_LEADER=claude-haiku-4-5-20251001
MODEL_ANALYST=claude-haiku-4-5-20251001
MODEL_WRITER=claude-haiku-4-5-20251001

MAX_RETRIES=3
RETRY_DELAY_SECONDS=5
LOG_LEVEL=INFO

DATA_RAW_DIR=data/raw
DATA_ANALYSIS_DIR=data/analysis
OUTPUT_DIR=output
LOGS_DIR=logs

RSS_EXPANSION=https://www.expansion.com/rss/mercados.xml
RSS_CINCO_DIAS=https://cincodias.elpais.com/seccion/rss/mercados/

# Descomentar para forzar ejecución fuera de horario (pruebas locales)
# FORCE_RUN=true

# ── Newsletter / API (Fase 1) ────────────────────────────────────────────────
# PostgreSQL — OBLIGATORIO para newsletter y API
# Local: postgresql://user:password@localhost:5432/ibex_newsletter
# Railway: se inyecta automáticamente desde el addon PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/ibex_newsletter

# SendGrid — OBLIGATORIO para envío de emails
SENDGRID_API_KEY=SG.xxxx...
SENDGRID_FROM_EMAIL=newsletter@tudominio.com

# Puerto de la API Flask (por defecto 5000)
# PORT=5000
# FLASK_DEBUG=false
